# Web + GitHub OAuth
NEXT_PUBLIC_APP_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
KILN_REQUIRE_AUTH=0

# Production persistence and queue
DATABASE_URL=
KILN_DB_AUTO_MIGRATE=0
REDIS_URL=
KILN_QUEUE_MODE=local
RUNNER_ENABLE_QUEUE=0
KILN_S3_BUCKET=
KILN_S3_REGION=us-east-1
KILN_S3_ENDPOINT=
KILN_S3_FORCE_PATH_STYLE=0
KILN_S3_PREFIX=

# Runner sandbox selection
KILN_SANDBOX_MODE=local
KILN_FIRECRACKER_MANAGER_URL=http://127.0.0.1:8787
KILN_FIRECRACKER_MANAGER_TOKEN=

# Linux/KVM host manager
KILN_FIRECRACKER_MANAGER_HOST=127.0.0.1
KILN_FIRECRACKER_MANAGER_PORT=8787
KILN_FIRECRACKER_BIN=firecracker
KILN_FIRECRACKER_KERNEL=
KILN_FIRECRACKER_ROOTFS=
KILN_FIRECRACKER_SSH_KEY=
KILN_FIRECRACKER_WORK_DIR=/var/lib/kiln
KILN_FIRECRACKER_BOOT_TIMEOUT_MS=15000
KILN_FIRECRACKER_MEMORY_MIB=1024
KILN_FIRECRACKER_VCPU_COUNT=2

# Agent CLIs inside the guest. Override commands only when image flags differ.
KILN_AGENT_FALLBACK=0
KILN_AGENT_USE_CLI=0
KILN_CLAUDE_COMMAND=
KILN_CODEX_COMMAND=
KILN_CURSOR_COMMAND=

# Claude Code via Amazon Bedrock. Fill exactly one AWS credential path:
# AWS_PROFILE, AWS access key fields, or AWS_BEARER_TOKEN_BEDROCK.
CLAUDE_CODE_USE_BEDROCK=0
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_BEARER_TOKEN_BEDROCK=
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_SMALL_FAST_MODEL_AWS_REGION=

# LLM judge
ANTHROPIC_API_KEY=
KILN_LLM_JUDGE_MODEL=
